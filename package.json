{
  "name": "zen-vanguard-program",
  "private": true,
  "version": "3.1.0",
  "description": "ZEN Vanguard professional AI literacy platform with guided curriculum, certifications, payments, and operational telemetry.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "start": "node server/index.js",
    "check": "tsc --noEmit",
    "build": "vite build",
    "preview:vite": "vite preview",
    "preview": "node scripts/preview-runtime-server.cjs --host 127.0.0.1 --port 4173",
    "preview:open": "node scripts/preview-runtime-server.cjs --host 127.0.0.1 --port 4173",
    "preview:static": "node scripts/serve-static-preview.cjs --host 127.0.0.1 --port 4173",
    "preview:diagnose": "node scripts/diagnose-preview-runtime.cjs"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@mermaid-js/parser": "^1.1.0",
    "@supabase/supabase-js": "^2.93.1",
    "cors": "^2.8.5",
    "cytoscape": "^3.33.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mermaid": "^11.14.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.0",
    "react-router-dom": "^7.1.0",
    "resend": "^6.10.0",
    "stripe": "^14.10.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  }
}
