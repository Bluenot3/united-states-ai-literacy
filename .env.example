# ZEN Vanguard — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# ─── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# ─── Express API ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001

# ─── Feature Flags ─────────────────────────────────────────────
# Set to "true" to enable demo/preview login without Supabase
VITE_ENABLE_DEMO_LOGIN=false

# ─── Stripe ────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<your-key>

# ─── Server-side only (not VITE_ prefixed, not exposed to browser) ──
STRIPE_SECRET_KEY=sk_test_<your-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-secret>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
RESEND_API_KEY=re_<your-key>
ADMIN_USERNAME=<admin-username>
ADMIN_PASSWORD=<admin-password>
