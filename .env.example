# ============================================================
# ZEN Vanguard — Environment Variables Reference
# ============================================================
# Copy this file to .env (server) and .env.local (frontend).
# Never commit real keys to version control.
#
# QUICK START:
#   1. Supabase  — create project at https://supabase.com/dashboard
#      Run supabase_setup.sql in your project SQL editor to set up tables.
#   2. Resend    — create account at https://resend.com
#   3. Stripe    — create account at https://stripe.com
#   4. Azure AI  — provision an Azure OpenAI resource (or skip for no AI)
#   5. Fill in the values below and run: npm install && npm run dev:full
# ============================================================


# ── Frontend (VITE_* vars are bundled into the browser build) ──────────────

# Your Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key (Project Settings → API → anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Base URL of the API server (Express backend)
# Local dev: http://localhost:3001 | Production: https://your-api.yourdomain.com
VITE_API_BASE_URL=http://localhost:3001

# Stripe publishable key (Stripe Dashboard → Developers → API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Set to "true" to show demo login hint (dev / staging only — never production)
VITE_ENABLE_DEMO_LOGIN=false

# Browser-local AI for Programs. WebLLM uses WebGPU in supported browsers and
# never requires an API key. Keep template fallback enabled for unsupported devices.
VITE_ENABLE_WEBLLM=true
VITE_ENABLE_WEBLLM_AUTO_ROUTE=true
VITE_ENABLE_TEMPLATE_AI_FALLBACK=true


# ── Server (NOT bundled — backend API only) ────────────────────────────────

# Port the Express API server listens on
API_PORT=3001

# Comma-separated allowed CORS origins (include your frontend production URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.yourdomain.com

# Your deployed app URL — used in email links and Stripe redirect URLs
APP_URL=https://your-frontend.yourdomain.com


# ── Supabase service role (server-side privileged DB operations) ─────────────
# KEEP THIS SECRET — never expose it in frontend code or version control.
# Find it in: Project Settings → API → service_role secret key
# Required for the server to update user entitlements after Stripe payment.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>


# ── Resend (transactional email) ─────────────────────────────────────────────
#
# Without RESEND_API_KEY, emails are logged to console (safe for local dev).
# Supabase auth emails (confirm account, reset password) are handled by
# Supabase separately — Resend covers welcome and certificate emails.
#
# Setup steps:
#   1. Sign up at https://resend.com (free tier: 3,000 emails/month)
#   2. Add and verify your sending domain under "Domains"
#   3. Create an API key under "API Keys" (Sending access)
#   4. Set RESEND_FROM_EMAIL to an address on your verified domain

RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=ZEN Vanguard <noreply@yourdomain.com>
RESEND_REPLY_TO=support@yourdomain.com


# ── Azure AI (AI Advisor + module AI features) ───────────────────────────────
#
# Powers the AI Advisor chatbot and interactive AI components.
# Provision an Azure OpenAI resource, deploy your chosen model, then fill in:
#   Endpoint: Azure Portal → Your OpenAI resource → Keys and Endpoint
#   Key:      Azure Portal → Your OpenAI resource → Keys and Endpoint → Key 1
#
# If left blank, AI features return a graceful "not configured" message.

AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_AI_KEY=replace_me
AZURE_AI_MODEL=Kimi-K2.5
AZURE_AI_API_VERSION=2024-12-01-preview


# ── Stripe (subscription payments) ──────────────────────────────────────────
#
# Setup steps:
#   1. Create a Product in Stripe Dashboard with a recurring Price
#   2. Copy the Price ID (starts with price_) from the price detail page
#   3. Add a webhook endpoint pointing to: POST /api/stripe/webhook
#      Events to enable:
#        checkout.session.completed
#        customer.subscription.updated
#        customer.subscription.deleted
#   4. Copy the webhook signing secret (starts with whsec_) from the webhook page

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me

# Optional tier-specific recurring Price IDs. Leave blank until those Stripe
# Prices exist. STRIPE_PRICE_ID remains the legacy fallback and maps to Pro.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_EDUCATOR=
STRIPE_PRICE_FAMILY=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ORG=


# ── Admin bypass (internal staff access without Stripe subscription) ─────────
#
# Allows authorized staff to bypass the paywall via the hidden "Internal admin
# access" link. Leave both blank to disable the bypass entirely.

ADMIN_BYPASS_USERNAME=replace_me
ADMIN_BYPASS_PASSWORD=replace_me
