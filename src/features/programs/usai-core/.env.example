# ZEN Vanguard — USAI Core Environment Variables
# Copy this file to .env.local and fill in real values before running.
# NEVER commit .env.local to version control.

# ─── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# ─── Express API ───────────────────────────────────────────────
# URL where the Express backend (server/index.js) is running
VITE_API_BASE_URL=http://localhost:3001

# ─── Feature Flags ─────────────────────────────────────────────
# Set to "true" to enable demo/preview login without Supabase auth
VITE_ENABLE_DEMO_LOGIN=false

# ─── Stripe ────────────────────────────────────────────────────
# Public-facing Stripe publishable key (safe in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<your-key>
