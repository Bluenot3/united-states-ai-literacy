# Feature flags — safe to commit, no secrets here.
# Real credentials go in .env.local (gitignored).

# Enable demo/preview mode so all programs are accessible without Supabase auth.
# This is intentional for Lovable preview and staging deployments.
VITE_ENABLE_DEMO_LOGIN=false

# API base — override in .env.local for production
VITE_API_BASE_URL=http://localhost:3001
